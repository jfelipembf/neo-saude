# Copie para .env e preencha com os valores do seu projeto Supabase
# (Dashboard → Project Settings → API). O .env é ignorado pelo git.
#
# SEM .env o app roda inteiro em MODO MOCK (ver src/lib/supabase.ts) — nada
# quebra; os services devolvem os dados de src/mocks/.
#
# Projeto atual: "neosaude" · região sa-east-1 (São Paulo) · Postgres 17
# Ref: cchbamuhjvxxayokklux
VITE_SUPABASE_URL=https://cchbamuhjvxxayokklux.supabase.co

# Chave PUBLICÁVEL — vai no bundle do navegador por design; quem protege o dado
# é a RLS, não o segredo desta chave. NUNCA use a service_role key aqui.
VITE_SUPABASE_ANON_KEY=sb_publishable_c-WJdANw_ZnsK5ftKoClTw_czHiYd_O
